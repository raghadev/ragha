#!/usr/bin/env python3
"""
agent-research — pesquisa web PREVIA e condensada. O harness roda isto ANTES da tarefa
e injeta o resultado no contexto, pra QUALQUER modelo (mesmo burro) agir com info atual.
Uso: agent-research "consulta" [n]
Imprime um bloco curto "PESQUISA WEB (fresca)" com fontes. Silencioso se nada achar.
"""
import sys, re

def main():
    if len(sys.argv) < 2:
        return
    query = sys.argv[1].strip()
    k = int(sys.argv[2]) if len(sys.argv) > 2 else 4
    try:
        from ddgs import DDGS
    except Exception:
        try:
            from duckduckgo_search import DDGS
        except Exception as e:
            print(f"[research indisponivel: {e}]"); return
    try:
        results = list(DDGS().text(query, max_results=k))
    except Exception as e:
        print(f"[research falhou: {e}]"); return
    if not results:
        return
    out = ["FATOS ATUAIS DA WEB (use estes; nao a memoria de treino):"]
    urls = []
    for r in results[:3]:
        t = (r.get("title") or "").strip()[:70]
        u = (r.get("href") or r.get("url") or "").strip()
        b = re.sub(r"\s+", " ", (r.get("body") or "")).strip()[:110]
        out.append(f"- {t}: {b} [{u}]")
        if u:
            urls.append(u)
    # TRECHO DA PAGINA: busca o conteudo do 1o resultado -> o dado (versao/numero/preco) fica presente
    # mesmo quando o snippet nao traz. Prioriza linhas com numeros/versoes (mais informativas).
    try:
        import httpx
        from bs4 import BeautifulSoup
        for u in urls[:2]:
            try:
                html = httpx.get(u, timeout=8, follow_redirects=True,
                                 headers={"User-Agent": "Mozilla/5.0"}).text
                soup = BeautifulSoup(html, "html.parser")
                for tag in soup(["script", "style", "nav", "footer", "header"]):
                    tag.extract()
                text = re.sub(r"\s+", " ", soup.get_text(" ")).strip()
                # frases com numero/versao primeiro (ex "Python 3.13.1", "latest 3.13")
                sents = re.split(r"(?<=[.!?])\s+", text)
                hot = [s for s in sents if re.search(r"\d+\.\d+", s)][:4]
                excerpt = " ".join(hot) if hot else text[:400]
                excerpt = excerpt[:500]
                if excerpt:
                    out.append(f"TRECHO DA PAGINA [{u}]: {excerpt}")
                    break
            except Exception:
                continue
    except Exception:
        pass
    print("\n".join(out))


if __name__ == "__main__":
    main()
