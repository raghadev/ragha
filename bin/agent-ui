// chat
const log=$('#log'),q=$('#q'),go=$('#go'),welcome=$('#welcome'),thread=$('#thread');
function turn(who,label){const t=document.createElement('div');t.className='turn '+who;
 t.innerHTML='<div class=who>'+label+'</div>';const b=document.createElement('div');b.className='bubble';
 t.appendChild(b);log.appendChild(t);thread.scrollTop=thread.scrollHeight;return b;}
function grow(){q.style.height='auto';q.style.height=Math.min(q.scrollHeight,180)+'px'}
q.addEventListener('input',grow);
async function send(){const text=q.value.trim();if(!text)return;welcome.style.display='none';
 turn('user','Você').textContent=text;q.value='';grow();go.disabled=true;
 const b=turn('ai','ragha');b.innerHTML='<div class=think><b></b><b></b><b></b></div>';
 try{const d=await(await fetch('/ask',{method:'POST',headers:{'Content-Type':'application/json'},
   body:JSON.stringify({prompt:text,model:$('#model').value,deepweb:DEEP,mode:MODE,think:THINK})})).json();
  b.textContent=d.output||d.error||'(sem resposta)';
 }catch(e){b.textContent='Erro: '+e}
 go.disabled=false;q.focus();refresh();thread.scrollTop=thread.scrollHeight;}
go.onclick=send;q.addEventListener('keydown',e=>{if(e.key==='Enter'&&!e.shiftKey){e.preventDefault();send()}});
$('#new').onclick=()=>{log.innerHTML='';welcome.style.display=''};
$('#think').onclick=e=>{THINK=!THINK;e.target.classList.toggle('act',THINK)};
$('#deep').onclick=e=>{DEEP=!DEEP;e.target.classList.toggle('act',DEEP)};
$('#mode').onclick=e=>{MODE=MODE==='auto'?'bypass':'auto';e.target.textContent=MODE==='auto'?'⚡ Automático':'🔓 Bypass';};
// voz
const mic=$('#mic');const SR=window.SpeechRecognition||window.webkitSpeechRecognition;
if(SR){const rec=new SR();rec.lang='pt-BR';rec.continuous=false;rec.interimResults=true;let on=false;
 mic.onclick=()=>{if(on){rec.stop();return}rec.start()};
 rec.onstart=()=>{on=true;mic.classList.add('rec')};rec.onend=()=>{on=false;mic.classList.remove('rec')};
 rec.onresult=e=>{let t='';for(const r of e.results)t+=r[0].transcript;q.value=t;grow()};
}else{mic.title='ditado indisponível aqui (abra no Chrome)';mic.style.opacity=.4}
// status
async function refresh(){try{const s=await(await fetch('/status')).json();
 $('#foot').innerHTML=`<span><i class="dot ${s.ollama?'':'off'}"></i>Ollama · <i class="dot ${s.tor?'':'off'}"></i>Tor</span><span>RAM livre ${s.ram} · ${s.mode==='bypass'?'🔓 bypass':'⚡ auto'}</span>`;
 const cur=s.model;const fill=sel=>{if(sel.dataset.done)return;sel.innerHTML='';s.models.forEach(m=>{const o=document.createElement('option');o.value=m;o.textContent=m.replace(':latest','');if(m===cur)o.selected=true;sel.appendChild(o)});sel.dataset.done=1};
 fill($('#model'));const sm=$('#setmodel');sm.dataset.done='';fill(sm);
 MODE=s.mode==='bypass'?'bypass':'auto';$('#mode').textContent=MODE==='auto'?'⚡ Automático':'🔓 Bypass';
 $$('.modeopt').forEach(x=>x.classList.toggle('act',x.dataset.m===MODE));
 }catch(e){$('#foot').textContent='sem conexão'}}
refresh();setInterval(refresh,9000);
// models panel
async function loadModels(){const d=await(await fetch('/models')).json();
 $('#modellist').innerHTML=d.map(m=>`<div class="card"><div class="row"><b>${m.name.replace(':latest','')}</b>
  <span class="pill ${(m.verdict||'').includes('READY')?'ok':(m.verdict||'').includes('CHAT')?'bad':'warn'}">${m.verdict||'—'}</span>
  <span class="grow"></span><span style="color:var(--muted);font-size:12px">${m.size||''}</span></div>
  ${m.limits?'<div class="sub" style="margin:8px 0 0">'+m.limits+'</div>':''}</div>`).join('')||'<div class=sub>nenhum modelo configurado ainda</div>';}
$('#pull').onclick=async()=>{const ref=$('#hf').value.trim();if(!ref)return;const st=$('#pullstatus');
 st.innerHTML='<span class=spin></span> baixando e configurando… (pode demorar)';
 await fetch('/pull',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({ref,alias:$('#hfalias').value.trim()})});
 const poll=setInterval(async()=>{const r=await(await fetch('/pull-log')).text();st.innerText=r.slice(-600);
  if(r.includes('== veredito ==')||r.includes('FAIL')){clearInterval(poll);loadModels();refresh();}},2500);}
// routines
async function loadRoutines(){const d=await(await fetch('/routines')).json();
 $('#routinelist').innerHTML=d.map(r=>`<div class="card"><div class="row"><b>${r.name}</b>
  <span class="pill ok">${r.quando}</span><span class="grow"></span>
  <button class="btn ghost" onclick="runRoutine('${r.id}')">rodar agora</button>
  <button class="btn ghost" onclick="delRoutine('${r.id}')">apagar</button></div>
  <div class="sub" style="margin:8px 0 0">${r.prompt}</div></div>`).join('')||'<div class=sub>nenhuma rotina</div>';}
$('#raddb').onclick=async()=>{await fetch('/routines',{method:'POST',headers:{'Content-Type':'application/json'},
  body:JSON.stringify({name:$('#rname').value,prompt:$('#rprompt').value,time:$('#rtime').value})});
 $('#rname').value='';$('#rprompt').value='';loadRoutines();}
window.delRoutine=async id=>{await fetch('/routines?id='+id,{method:'DELETE'});loadRoutines();}
window.runRoutine=async id=>{await fetch('/routines/run?id='+id,{method:'POST'});}
// skills
async function loadSkills(){const d=await(await fetch('/skills')).json();
 $('#skilllist').innerHTML=d.map(s=>`<div class="card"><b>${s.nome}</b></div>`).join('')||'<div class=sub>nenhuma skill instalada</div>';}
async function skDo(install){const url=$('#skurl').value.trim();if(!url)return;const st=$('#skstatus');
 st.innerHTML='<span class=spin></span> analisando…';
 const d=await(await fetch('/skills',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({url,install})})).json();
 const cls=d.verdict==='SEGURO'?'ok':d.verdict==='SUSPEITO'?'warn':'bad';
 st.innerHTML=`<span class="pill ${cls}">${d.verdict}</span> ${d.msg||''} ${(d.hits||[]).map(h=>'• '+h.risco).join(' ')}`;loadSkills();}
$('#skscan').onclick=()=>skDo(false);$('#skinstall').onclick=()=>skDo(true);
// settings
$('#setmodelb').onclick=async()=>{await fetch('/setmodel',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({model:$('#setmodel').value})});refresh();}
$$('.modeopt').forEach(o=>o.onclick=async()=>{await fetch('/setmode',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({mode:o.dataset.m})});refresh();});
q.focus();
</script></body></html>"""

_ANSI = _re.compile(r"\x1b\[[0-9;]*m")
_NOISE = ("OK   ", "FIX  ", "WARN ", "FAIL ", "goose is ready", "new session", "__( O)>",
          "\\____)", "L L", "Deps deepweb", "Ollama no ar", "Modelo presente", "config.yaml",
          "[agent]", "[config-guard]", "== ", "agent-doctor", "───", "▸ ", "path ",
          "command:", "content:", "reflect:", "mem:", "💡")


def clean(raw):
    return "\n".join(s.strip() for l in _ANSI.sub("", raw).splitlines()
                      for s in [l.strip()] if s and not any(t in l for t in _NOISE)).strip()


def sh(cmd, t=30):
    try: return subprocess.run(cmd, capture_output=True, text=True, timeout=t).stdout.strip()
    except Exception: return ""


def cfg_get(key):
    return sh(["bash", "-c", f"awk -F': ' '/^{key}:/{{print $2}}' {CFG}"])


def status():
    import urllib.request
    ollama = False
    try: urllib.request.urlopen("http://localhost:11434/api/version", timeout=2); ollama = True
    except Exception: pass
    tor = sh(["bash", "-c", "nc -z 127.0.0.1 9050 && echo 1"]) == "1"
    ram = sh(["bash", "-c", "memory_pressure 2>/dev/null | awk -F: '/free percentage/{print $2}'"]).strip() or "?"
    models = [l.split()[0] for l in sh(["ollama", "list"]).splitlines()[1:] if l.strip()]
    mode = "bypass" if cfg_get("GOOSE_MODE") == "auto" else "auto"
    return {"ollama": ollama, "tor": tor, "ram": ram, "models": models,
            "model": cfg_get("GOOSE_MODEL"), "mode": "auto"}


def models_detail():
    plugged = {}
    try:
        for line in open(f"{HOME}/.local/state/agent/plugged.tsv"):
            p = line.split("\t")
            if len(p) >= 6: plugged[p[0]] = p[5].strip()
    except FileNotFoundError:
        pass
    out = []
    for l in sh(["ollama", "list"]).splitlines()[1:]:
        if not l.strip(): continue
        c = l.split(); name = c[0]
        limits = ""
        for cand in (name, name.replace(":latest", "")):
            p = f"{HOME}/.local/state/agent/model-limits/{cand}.txt"
            if os.path.exists(p):
                limits = open(p).read().strip(); break
        out.append({"name": name, "size": c[2] + c[3] if len(c) > 3 else "",
                    "verdict": plugged.get(name, plugged.get(name.replace(":latest", ""), "")),
                    "limits": limits})
    return out


class H(BaseHTTPRequestHandler):
    def _s(self, code, body, ctype="application/json"):
        b = body.encode() if isinstance(body, str) else body
        self.send_response(code); self.send_header("Content-Type", ctype)
        self.send_header("Content-Length", str(len(b))); self.end_headers(); self.wfile.write(b)

    def _body(self):
        n = int(self.headers.get("Content-Length", 0))
        try: return json.loads(self.rfile.read(n) or "{}")
        except Exception: return {}

    def do_GET(self):
        p = urllib.parse.urlparse(self.path); path = p.path
        if path == "/": self._s(200, PAGE, "text/html; charset=utf-8")
        elif path == "/status": self._s(200, json.dumps(status()))
        elif path == "/models": self._s(200, json.dumps(models_detail()))
        elif path == "/pull-log":
            try: self._s(200, open(PULLLOG).read(), "text/plain")
            except FileNotFoundError: self._s(200, "", "text/plain")
        elif path == "/routines": self._s(200, sh([f"{BIN}/agent-routine", "list"]) or "[]")
        elif path == "/skills": self._s(200, sh([f"{BIN}/agent-skill", "list"]) or "[]")
        else: self._s(404, "{}")

    def do_POST(self):
        p = urllib.parse.urlparse(self.path); path = p.path
        qs = urllib.parse.parse_qs(p.query)
        if path == "/ask":
            d = self._body(); prompt = (d.get("prompt") or "").strip()
            if not prompt: self._s(400, json.dumps({"error": "vazio"})); return
            cmd = [AGENT]
            if d.get("model"): cmd += ["--model", d["model"]]
            if d.get("deepweb"): cmd += ["--deepweb"]
            if d.get("think"): prompt = "Pense passo a passo antes de agir. " + prompt
            cmd.append(prompt)
            env = dict(os.environ)
            try:
                raw = subprocess.run(cmd, capture_output=True, text=True, timeout=600, env=env).stdout
                self._s(200, json.dumps({"output": clean(raw) or "(sem saída)"}))
            except subprocess.TimeoutExpired:
                self._s(200, json.dumps({"error": "demorou demais. Tente algo menor ou o modelo leve."}))
            except Exception as e:
                self._s(200, json.dumps({"error": str(e)}))
        elif path == "/pull":
            d = self._body(); ref = d.get("ref", "").strip()
            args = [f"{BIN}/agent-plug", ref] + ([d["alias"]] if d.get("alias") else []) + ["--set"]
            open(PULLLOG, "w").write("iniciando…\n")
            subprocess.Popen(["bash", "-lc", " ".join(f"'{a}'" for a in args) + f" >> {PULLLOG} 2>&1"])
            self._s(200, json.dumps({"ok": True}))
        elif path == "/setmodel":
            m = self._body().get("model", "")
            if m: sh(["bash", "-c", f"sed -i '' 's#^GOOSE_MODEL:.*#GOOSE_MODEL: {m}#' {CFG}"])
            self._s(200, json.dumps({"ok": True}))
        elif path == "/setmode":
            self._s(200, json.dumps({"ok": True}))  # ambos rodam auto no headless; guardbin sempre on
        elif path == "/routines":
            d = self._body(); hh = d.get("time", "08:00")
            out = sh([f"{BIN}/agent-routine", "add", d.get("name", "rotina"), d.get("prompt", ""), hh])
            self._s(200, out or "{}")
        elif path == "/routines/run":
            self._s(200, sh([f"{BIN}/agent-routine", "run", qs.get("id", [""])[0]]) or "{}")
        elif path == "/skills":
            d = self._body(); url = d.get("url", "")
            verb = "install" if d.get("install") else "scan"
            self._s(200, sh([f"{BIN}/agent-skill", verb, url], t=120) or "{}")
        else: self._s(404, "{}")

    def do_DELETE(self):
        p = urllib.parse.urlparse(self.path); qs = urllib.parse.parse_qs(p.query)
        if p.path == "/routines":
            self._s(200, sh([f"{BIN}/agent-routine", "rm", qs.get("id", [""])[0]]) or "{}")
        else: self._s(404, "{}")

    def log_message(self, *a): pass


def main():
    srv = ThreadingHTTPServer(("127.0.0.1", PORT), H)
    url = f"http://127.0.0.1:{PORT}"
    print(f"ragha rodando em {url}")
    if os.environ.get("AGENT_UI_NOBROWSER") != "1":
        threading.Timer(1.0, lambda: webbrowser.open(url)).start()
    try: srv.serve_forever()
    except KeyboardInterrupt: print("\nencerrado.")


if __name__ == "__main__":
    main()
