#!/usr/bin/env bash
# agent-modelcheck — diagnostico automatico de QUALQUER modelo plugado.
# Detecta problemas comuns que travam o agente e recomenda o fix (com fontes).
# Uso: agent-modelcheck [MODELO]   (default = GOOSE_MODEL do config)
# Saida: relatorio leigo no stdout + JSON em ~/.config/agent/models/<modelo>.json
set -uo pipefail

CFG="$HOME/.config/goose/config.yaml"
OLL="http://localhost:11434"
MODEL="${1:-$(awk -F': ' '/^GOOSE_MODEL:/{print $2}' "$CFG" 2>/dev/null)}"
[ -z "$MODEL" ] && { echo "uso: agent-modelcheck MODELO"; exit 2; }
OUTDIR="$HOME/.config/agent/models"; mkdir -p "$OUTDIR"
JSON="$OUTDIR/${MODEL//[:\/]/_}.json"

command -v ollama >/dev/null 2>&1 || { echo "ollama nao encontrado"; exit 1; }
curl -s --max-time 3 "$OLL/api/version" >/dev/null 2>&1 || { echo "ollama fora do ar (rode: brew services start ollama)"; exit 1; }

echo "== diagnostico do modelo: $MODEL =="

# tmp de request com 1 tool (shell)
REQ=$(mktemp); REQF=$(mktemp)
cat > "$REQ" <<JSON
{"model":"$MODEL","stream":false,
"tools":[{"type":"function","function":{"name":"shell","description":"run a shell command","parameters":{"type":"object","properties":{"command":{"type":"string"}},"required":["command"]}}}],
"messages":[{"role":"system","content":"Voce e um agente com ferramentas. Use as ferramentas disponiveis."},{"role":"user","content":"Crie /tmp/mc.txt com OK. Chame a ferramenta shell agora."}]}
JSON
sed 's/"stream":false,/"stream":false,"think":false,/' "$REQ" > "$REQF"

# 1) capabilities declaradas
CAPS="$(ollama show "$MODEL" 2>/dev/null | awk '/Capabilities/{f=1;next} f&&/^ *[a-z]/{print $1} f&&/^$/{f=0}' | tr '\n' ' ')"
has(){ printf '%s' "$CAPS" | grep -qw "$1" && echo 1 || echo 0; }
CAP_TOOLS=$(has tools); CAP_VISION=$(has vision); CAP_THINK=$(has thinking)

# 2) num_ctx (Goose precisa >=16384 senao estoura)
NCTX="$(ollama show "$MODEL" 2>/dev/null | awk '/num_ctx|context length/{for(i=1;i<=NF;i++) if($i ~ /^[0-9]+$/) print $i}' | tail -1)"
[ -z "$NCTX" ] && NCTX="?"

# 3) probe THINK ON (como Goose manda hoje): mede thinking + tool + tempo
probe(){ # $1 = arquivo request
  curl -s --max-time 120 "$OLL/api/chat" -d @"$1" 2>/dev/null | python3 -c "
import sys,json
try: d=json.load(sys.stdin)
except: print('ERR|0|0|0|0'); sys.exit()
m=d.get('message',{})
th=len(m.get('thinking','') or ''); ct=len(m.get('content','') or '')
tc=len(m.get('tool_calls',[]))
ec=d.get('eval_count',0); ed=d.get('eval_duration',1)/1e9
tt=d.get('total_duration',0)/1e9
print(f'{tc}|{th}|{ct}|{round(tt,1)}|{round(ec/ed,1) if ed else 0}')
"
}
echo "  probando (think ON)…"; ON="$(probe "$REQ")"
echo "  probando (think OFF)…"; OFF="$(probe "$REQF")"
IFS='|' read -r ON_TC ON_TH ON_CT ON_T ON_TPS <<<"$ON"
IFS='|' read -r OFF_TC OFF_TH OFF_CT OFF_T OFF_TPS <<<"$OFF"

# ---- veredictos ----
warns=(); fixes=(); srcs=()
ok(){   printf "  \033[32mOK\033[0m   %s\n" "$1"; }
warn(){ printf "  \033[33mAVISO\033[0m %s\n" "$1"; warns+=("$1"); }
bad(){  printf "  \033[31mFALHA\033[0m %s\n" "$1"; warns+=("$1"); }

# tool-calling
if [ "${ON_TC:-0}" -ge 1 ] 2>/dev/null; then ok "Chama ferramentas (tool-calling real)"
else bad "NAO chama ferramentas (narra em vez de executar)"
  fixes+=("Modelo fraco em tool-call: use as capacidades via shell (comando 'mac'/scripts) que ele chama por developer__shell; ou troque por um modelo treinado em function-calling (familia Qwen).")
  srcs+=("Regra: tool-call=treino+template, nao tamanho")
fi

# thinking-loop
TH_HI=800
if [ "${CAP_THINK:-0}" = "1" ] && [ "${ON_TH:-0}" -gt "$TH_HI" ] 2>/dev/null; then
  warn "THINKING-LOOP: gera ${ON_TH} chars de 'pensamento' por turno (divaga, lento: ${ON_T}s)"
  # prova do think:false (quando a probe OFF reduziu) reforca a recomendacao
  if [ "${OFF_TH:-9999}" -lt "${ON_TH:-0}" ] 2>/dev/null; then
    fixes+=("DESLIGAR o pensamento (think:false) e o fix: na prova, caiu de ${ON_TH} -> ${OFF_TH} chars (${ON_T}s -> ${OFF_T}s). Botao 'Desligar pensamento' chega no proximo update do app [P1].")
  else
    fixes+=("DESLIGAR o pensamento (think:false) e o fix recomendado. Botao 'Desligar pensamento' chega no proximo update do app [P1]. Alternativa: usar a variante Instruct (nao-Thinking) deste modelo.")
  fi
  srcs+=("Ollama /api/chat aceita \"think\": false p/ desligar o raciocinio")
elif [ "${CAP_THINK:-0}" = "1" ]; then ok "Tem thinking mas sob controle (${ON_TH} chars)"
fi

# narracao como texto (content grande sem tool)
if [ "${ON_TC:-0}" = "0" ] && [ "${ON_CT:-0}" -gt 200 ] 2>/dev/null; then
  warn "NARRA em texto (${ON_CT} chars de resposta, 0 ferramenta chamada)"
fi

# contexto
if [ "$NCTX" != "?" ] && [ "${NCTX:-0}" -lt 16384 ] 2>/dev/null; then
  bad "num_ctx=${NCTX} < 16384 -> Goose ESTOURA ('exceeds the available context size')"
  fixes+=("Recrie o modelo com PARAMETER num_ctx 16384 (Modelfile) ou rode agent-plug $MODEL.")
else ok "Contexto ok (num_ctx=${NCTX})"; fi

# vision
[ "${CAP_VISION:-0}" = "1" ] && ok "Visao (le imagens)" || warn "Sem visao (nao le imagens)"

# velocidade
SP="${ON_TPS:-0}"; awk "BEGIN{exit !($SP>0 && $SP<8)}" && warn "Lento (${SP} tok/s) — tarefas longas demoram" || ok "Velocidade ${SP} tok/s"

# ---- resumo + JSON ----
echo; echo "  RESUMO: ${#warns[@]} ponto(s) de atencao."
if [ "${#fixes[@]}" -gt 0 ]; then echo "  FIXES sugeridos:"; for f in "${fixes[@]}"; do echo "   • $f"; done; fi
if [ "${#srcs[@]}" -gt 0 ]; then
  echo "  FONTES:"
  for s in "${srcs[@]}"; do echo "   - $s"; done
  echo "   - Qwen3-VL (visao+tools+thinking): https://ollama.com/library/qwen3-vl"
  echo "   - Ollama API (think): https://github.com/ollama/ollama/blob/main/docs/api.md"
fi

python3 - "$JSON" "$MODEL" "$CAP_TOOLS" "$CAP_VISION" "$CAP_THINK" "$NCTX" "$ON_TC" "$ON_TH" "$ON_T" "$ON_TPS" "$OFF_TC" "$OFF_TH" "$OFF_T" <<'PY'
import sys,json
p=sys.argv[1]
d=dict(model=sys.argv[2],tools=sys.argv[3]=='1',vision=sys.argv[4]=='1',thinking=sys.argv[5]=='1',
       num_ctx=sys.argv[6],think_on=dict(tool=sys.argv[7],think_chars=sys.argv[8],secs=sys.argv[9],tps=sys.argv[10]),
       think_off=dict(tool=sys.argv[11],think_chars=sys.argv[12],secs=sys.argv[13]))
json.dump(d,open(p,'w'),ensure_ascii=False,indent=2)
print("  (relatorio salvo em",p+")")
PY
rm -f "$REQ" "$REQF" /tmp/mc.txt 2>/dev/null
